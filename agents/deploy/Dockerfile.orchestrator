# Build stage - install build dependencies and compile packages
FROM --platform=linux/amd64 python:3.10-slim as builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    build-essential \
    libffi-dev \
    libssl-dev \
    cargo \
    && apt-get upgrade -y \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY agents/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Runtime stage - lightweight final image
FROM --platform=linux/amd64 python:3.10-slim

WORKDIR /app

# Install only runtime dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && apt-get upgrade -y \
    && rm -rf /var/lib/apt/lists/*

# Copy compiled packages from builder stage
COPY --from=builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy only orchestrator agent code and shared dependencies
COPY agents/orchestrator/ ./agents/orchestrator/
COPY agents/shared/ ./agents/shared/
COPY agents/__init__.py ./agents/
COPY agents/tools/ ./agents/tools/
COPY config/ ./config/

# Create non-root user
RUN groupadd -r appuser && useradd -r -g appuser appuser && \
    chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Set environment variables for orchestrator
ENV AGENT_TYPE=orchestrator
ENV AGENT_PORT=9001
ENV PROJECT_NAME=risk-agent
ENV AWS_REGION=us-east-1

# Expose orchestrator port
EXPOSE 9001

# Health check for orchestrator
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:9001/health || exit 1

# Run orchestrator agent
CMD ["python", "-m", "agents.orchestrator.main"]