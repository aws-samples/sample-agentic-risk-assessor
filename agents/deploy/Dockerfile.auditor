FROM --platform=linux/amd64 python:3.10-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY agents/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy only auditor agent code and shared dependencies
COPY agents/auditor/ ./agents/auditor/
COPY agents/shared/ ./agents/shared/
COPY agents/__init__.py ./agents/
COPY agents/tools/ ./agents/tools/
COPY config/ ./config/

# Create non-root user
RUN groupadd -r appuser && useradd -r -g appuser appuser && \
    chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Set environment variables for auditor
ENV AGENT_TYPE=auditor
ENV AGENT_PORT=9006
ENV PROJECT_NAME=risk-agent
ENV AWS_REGION=us-east-1

# Expose auditor port
EXPOSE 9006

# Health check for auditor
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:9006/health || exit 1

# Run auditor agent
CMD ["python", "agents/auditor/server.py"]